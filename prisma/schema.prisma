// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum ModuleType {
  LECTURE
  ASSIGNMENT
  QUIZ
}

enum SubmissionType {
  FILE
  QUIZ
}

enum SubmissionStatus {
  INCOMPLETE
  PASS
  FAIL
}

enum CourseStatus {
  INCOMPLETE
  PASSED
  DROPPED
}

model User {
  id        String   @id
  role      UserRole @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments    Comment[]    @relation("UserToComment")
  enrollments Enrollment[]
  managing    Managing[]
  submissions Submission[]

  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  sessions      Session[]
  accounts      Account[]
  uploads       File[]

  @@unique([email])
  @@map("user")
}

model Course {
  courseId          String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  courseName        String
  courseDescription String?
  totalEnrolled     BigInt   @default(0)
  totalCompleted    BigInt   @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  modules     Module[]     @relation("CourseToModule")
  comments    Comment[]    @relation("CourseToComment")
  enrollments Enrollment[]
  managing    Managing[]
}

model Comment {
  commentId   String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  commentText String
  courseId    String   @db.Uuid
  authorId    String
  authorRole  UserRole @default(STUDENT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation("CourseToComment", fields: [courseId], references: [courseId])
  author User   @relation("UserToComment", fields: [authorId], references: [id])
}

model Module {
  moduleId          String     @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  courseId          String     @db.Uuid
  moduleIndex       Int
  moduleType        ModuleType
  moduleTitle       String
  moduleDescription String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  quizConfig        Json?      // Stores: { timeLimit, maxAttempts, questions: [{ id, text, options: [], correctOptionIndex }] }
  assignmentConfig  Json?      // Stores: { dueDate: string }

  course          Course       @relation("CourseToModule", fields: [courseId], references: [courseId])
  moduleResources File[]       @relation("ModuleFiles")
  submissions     Submission[]
}

model Managing {
  instructorId String
  courseId     String @db.Uuid

  instructor User   @relation(fields: [instructorId], references: [id])
  course     Course @relation(fields: [courseId], references: [courseId])

  @@id([instructorId, courseId])
}

model Enrollment {
  studentId    String
  courseId     String       @db.Uuid
  courseStatus CourseStatus

  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [courseId])

  @@id([studentId, courseId])
}

model Submission {
  id               String           @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  studentId        String
  moduleId         String           @db.Uuid
  submissionStatus SubmissionStatus
  submissionGrade  Decimal
  submissionType   SubmissionType   @default(FILE) // Migration required a default value
  quizState        Json?            // Stores: { attempts: number, answers: Record<string, number>, timeSpent: number }
  assignmentState  Json?            // Stores: { fileUrl: string, submittedAt: string }

  student User   @relation(fields: [studentId], references: [id])
  module  Module @relation(fields: [moduleId], references: [moduleId])
  files   File[] @relation("SubmissionFiles")

  @@unique([studentId, moduleId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model File {
  id           String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  s3Path       String   @unique // GCS bucket URI
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())

  uploaderId   String
  uploader     User        @relation(fields: [uploaderId], references: [id])
  moduleId     String?     @db.Uuid
  module       Module?     @relation("ModuleFiles", fields: [moduleId], references: [moduleId])
  submissionId String?     @db.Uuid
  submission   Submission? @relation("SubmissionFiles", fields: [submissionId], references: [id])
}
