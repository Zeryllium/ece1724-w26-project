// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum ModuleType {
  LECTURE
  ASSIGNMENT
  QUIZ
}

enum SubmissionStatus {
  INCOMPLETE
  PASS
  FAIL
}

enum CourseStatus {
  INCOMPLETE
  PASSED
  DROPPED
}

model User {
  userId    String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  role      UserRole @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments    Comment[]    @relation("UserToComment")
  enrollments Enrollment[]
  managing    Managing[]
  submissions Submission[]

  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Course {
  courseId          String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  courseName        String
  courseDescription String?
  totalEnrolled     BigInt   @default(0)
  totalCompleted    BigInt   @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  modules     Module[]     @relation("CourseToModule")
  comments    Comment[]    @relation("CourseToComment")
  enrollments Enrollment[]
  managing    Managing[]
}

model Comment {
  commentId   String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  commentText String
  courseId    String   @db.Uuid
  authorId    String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation("CourseToComment", fields: [courseId], references: [courseId])
  author User   @relation("UserToComment", fields: [authorId], references: [userId])
}

model Module {
  moduleId          String     @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  courseId          String     @db.Uuid
  moduleIndex       Int
  moduleType        ModuleType
  moduleResourceUri String
  moduleTitle       String
  moduleDescription String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  course      Course       @relation("CourseToModule", fields: [courseId], references: [courseId])
  submissions Submission[]
}

model Managing {
  instructorId String @db.Uuid
  courseId     String @db.Uuid

  instructor User   @relation(fields: [instructorId], references: [userId])
  course     Course @relation(fields: [courseId], references: [courseId])

  @@id([instructorId, courseId])
}

model Enrollment {
  studentId    String       @db.Uuid
  courseId     String       @db.Uuid
  courseStatus CourseStatus

  student User   @relation(fields: [studentId], references: [userId])
  course  Course @relation(fields: [courseId], references: [courseId])

  @@id([studentId, courseId])
}

model Submission {
  studentId        String           @db.Uuid
  moduleId         String           @db.Uuid
  submissionStatus SubmissionStatus
  submissionGrade  Decimal

  student User   @relation(fields: [studentId], references: [userId])
  module  Module @relation(fields: [moduleId], references: [moduleId])

  @@id([studentId, moduleId])
}

model Session {
  id        String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [userId], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
